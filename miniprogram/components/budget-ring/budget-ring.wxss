.budget-ring-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: conic-gradient(
    var(--income) calc(var(--pct) * 1%),
    #F0F0F0 calc(var(--pct) * 1%)
  );
}

.ring-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--card);
  border-radius: 50%;
  width: 75%;
  height: 75%;
  justify-content: center;
}

.ring-percentage {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text);
}

.ring-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
