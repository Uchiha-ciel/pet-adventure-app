.category-picker { padding: 16rpx 0; }

.category-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  padding: 0 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.category-item.active {
  background: var(--primary);
  transform: scale(1.05);
}

.category-item.active .cat-name { color: #fff; }

.cat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.cat-emoji { font-size: 32rpx; }

.cat-name {
  font-size: 22rpx;
  color: var(--text);
  text-align: center;
}

.subcategory-panel {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  background: var(--bg);
  border-radius: 16rpx 16rpx 0 0;
  display: none;
}

.subcategory-panel.show { display: block; }

.sub-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text);
  margin-bottom: 12rpx;
}

.sub-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.sub-item {
  padding: 16rpx 12rpx;
  text-align: center;
  background: var(--card);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--text);
  transition: all 0.2s;
}

.sub-item:active {
  background: var(--primary);
  color: #fff;
  transform: scale(0.95);
}
