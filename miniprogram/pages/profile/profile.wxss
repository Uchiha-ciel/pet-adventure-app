.profile-page { min-height: 100vh; padding-bottom: 40rpx; }

.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
  margin-top: 24rpx;
}

.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), #FFB6C1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji { font-size: 48rpx; }

.profile-info { flex: 1; }
.profile-name { font-size: 36rpx; font-weight: bold; display: block; color: var(--text); }
.profile-stats { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; display: block; }

.menu-list { padding: 8rpx 0; }

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 16rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: var(--text); }
.menu-arrow { font-size: 36rpx; color: var(--text-secondary); }

.achievement-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.achievement-item {
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
}

.achievement-item.unlocked { background: var(--accent); }

.badge-emoji { font-size: 40rpx; display: block; margin-bottom: 8rpx; }
.achieve-name { font-size: 24rpx; color: var(--text); font-weight: bold; display: block; }
.achieve-desc { font-size: 20rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }

.achievement-item.locked .achieve-name { color: var(--text-secondary); }

.footer-text {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  padding: 40rpx 0;
}
