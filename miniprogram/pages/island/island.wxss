.island-page { min-height: 100vh; padding-bottom: 140rpx; }

.scene-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 32rpx;
  margin-top: 24rpx;
}

.pet-area { position: relative; margin-bottom: 24rpx; }

.pet-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), #FFB6C1);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 138, 0.3);
}

.pet-sprite-text { font-size: 72rpx; }

.pet-mood-bubble {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  background: var(--card);
  border-radius: 24rpx;
  padding: 8rpx 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.mood-emoji { font-size: 28rpx; }

.pet-status { text-align: center; }

.pet-name { font-size: 36rpx; font-weight: bold; color: var(--text); display: block; }

.stage-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.stage-baby { background: #FFE66D20; color: #FFB347; }
.stage-young { background: #4ECDC420; color: #4ECDC4; }
.stage-adult { background: #FF6B8A20; color: #FF6B8A; }

.today-row { display: flex; justify-content: space-around; margin-bottom: 24rpx; }
.today-item { text-align: center; }
.t-label { font-size: 24rpx; color: var(--text-secondary); display: block; }
.t-value { font-size: 32rpx; font-weight: bold; display: block; margin-top: 4rpx; }

.budget-row { display: flex; justify-content: center; }

.progress-outer {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  margin: 12rpx 0 8rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, var(--income), var(--primary));
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-label { font-size: 24rpx; color: var(--text-secondary); }

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.recent-item:last-child { border-bottom: none; }

.recent-cat { font-size: 28rpx; color: var(--text); }
.recent-amount { font-size: 28rpx; font-weight: bold; }

.center { text-align: center; }
.empty-hint { font-size: 28rpx; color: var(--text-secondary); display: block; }
.empty-sub { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; display: block; }

.fab {
  position: fixed;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, var(--primary), #FFB6C1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.4);
  z-index: 100;
}

.fab-icon { font-size: 56rpx; color: #fff; line-height: 1; }
