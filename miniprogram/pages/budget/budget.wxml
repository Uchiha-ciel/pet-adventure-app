<view class="budget-page">
  <view class="card">
    <text class="section-title">预算周期</text>
    <view class="period-row">
      <view class="period-option {{period === 'monthly' ? 'active' : ''}}" data-value="monthly" bindtap="onPeriodChange">
        <text>月度</text>
      </view>
      <view class="period-option {{period === 'weekly' ? 'active' : ''}}" data-value="weekly" bindtap="onPeriodChange">
        <text>周度</text>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="section-title">总预算</text>
    <view class="input-row">
      <text class="input-prefix">¥</text>
      <input class="budget-input" type="digit" placeholder="设置总预算金额"
        value="{{totalBudget}}" bindinput="onTotalInput" />
    </view>
  </view>

  <view class="card">
    <text class="section-title">分类预算（可选）</text>
    <view class="cat-budget-item" wx:for="{{expenseCategories}}" wx:key="id">
      <text class="cb-label">{{item.name}}</text>
      <view class="input-row small">
        <text class="input-prefix">¥</text>
        <input class="budget-input" type="digit" placeholder="不限"
          value="{{categoryBudgets[item.id] || ''}}"
          data-cat="{{item.id}}" bindinput="onCategoryInput" />
      </view>
    </view>
  </view>

  <view class="save-area">
    <button class="save-btn" bindtap="onSave" disabled="{{saving}}" loading="{{saving}}">保存预算</button>
  </view>
</view>
