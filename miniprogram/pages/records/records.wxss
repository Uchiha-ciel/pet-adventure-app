.records-page { min-height: 100vh; padding-bottom: 40rpx; }

.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  gap: 32rpx;
}

.month-title { font-size: 34rpx; font-weight: bold; color: var(--text); }

.month-arrow {
  font-size: 44rpx;
  color: var(--primary);
  padding: 0 16rpx;
}

.summary-bar {
  display: flex;
  margin: 0 24rpx 16rpx;
  gap: 16rpx;
}

.summary-item {
  flex: 1;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: var(--card);
  text-align: center;
}

.s-label { font-size: 24rpx; color: var(--text-secondary); display: block; }
.s-value { font-size: 36rpx; font-weight: bold; display: block; margin-top: 4rpx; }

.empty-state { padding: 120rpx 40rpx; text-align: center; }
.empty-emoji { font-size: 80rpx; display: block; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: var(--text-secondary); white-space: pre-line; line-height: 1.6; }

.loading-state { text-align: center; padding: 80rpx 0; color: var(--text-secondary); }

.bill-groups { padding: 0 24rpx; }

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 8rpx 12rpx;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 8rpx;
}

.group-date { font-size: 26rpx; color: var(--text-secondary); }
.group-summary { display: flex; gap: 16rpx; font-size: 24rpx; }

.bill-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 12rpx;
  background: var(--card);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.bill-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }

.bill-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.bill-info { display: flex; flex-direction: column; }

.bill-cat { font-size: 28rpx; color: var(--text); }
.bill-note { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }

.bill-right { display: flex; align-items: center; gap: 12rpx; }

.bill-amount { font-size: 30rpx; font-weight: bold; }

.bill-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  opacity: 0.5;
}
