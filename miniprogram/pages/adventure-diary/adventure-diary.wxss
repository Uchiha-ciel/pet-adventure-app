.diary-page { min-height: 100vh; }

.loading { text-align: center; padding: 80rpx; color: var(--text-secondary); }

.empty-state { padding: 120rpx 40rpx; text-align: center; }
.empty-emoji { font-size: 80rpx; display: block; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: var(--text-secondary); display: block; }
.empty-sub { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; display: block; }

.diary-list { padding: 16rpx 24rpx; }

.diary-card { margin: 0 0 16rpx; }

.diary-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12rpx;
}
.diary-month { font-size: 32rpx; font-weight: bold; color: var(--text); }
.diary-arrow { font-size: 26rpx; color: var(--primary); }

.diary-stats { display: flex; gap: 24rpx; font-size: 24rpx; color: var(--text-secondary); }

.story-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center;
  z-index: 1000;
}
.story-modal {
  width: 85vw; max-height: 70vh; overflow-y: auto;
  background: var(--card); border-radius: 24rpx; padding: 40rpx 32rpx;
}
.story-title { font-size: 34rpx; font-weight: bold; color: var(--text); display: block; margin-bottom: 24rpx; text-align: center; }
.story-section { padding: 16rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.story-text { font-size: 28rpx; color: var(--text); line-height: 1.6; }
.story-summary { font-size: 30rpx; font-weight: bold; color: var(--primary); display: block; margin-top: 24rpx; text-align: center; }
.story-close {
  margin-top: 32rpx; background: var(--primary); color: #fff;
  border-radius: 48rpx; font-size: 28rpx; padding: 16rpx 0; border: none;
}
